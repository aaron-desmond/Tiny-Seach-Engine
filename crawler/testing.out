echo -e "\n--- Test 6: Deep crawl matching course example (Letters, Depth 3) ---"

--- Test 6: Deep crawl matching course example (Letters, Depth 3) ---
./crawler http://cs50tse.cs.dartmouth.edu/tse/letters/index.html $TEST_DIR_2 3
